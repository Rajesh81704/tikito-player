{
  "expo": {
    "name": "Tikito",
    "slug": "tikito-player",
    "version": "1.0.0",
    "scheme": "tikito-player",
    "platforms": ["ios", "android"],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Tikito to access your location so we can show turfs in your city."
        }
      ],
      "./plugins/withAdiRegistration"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tikito.player"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tikito.player"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "34d962b7-f93f-4a44-abd2-b44195cd3c3e"
      }
    }
  }
}
